<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/keyboard_bg"
    android:paddingStart="3dp"
    android:paddingEnd="3dp"
    android:paddingBottom="8dp">

    <!-- Buffer display -->
    <TextView
        android:id="@+id/tv_buffer"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:background="@drawable/buffer_bg"
        android:textColor="@color/buffer_text"
        android:textSize="13sp"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:gravity="center_vertical"
        android:singleLine="true"
        android:ellipsize="start"
        android:fontFamily="monospace"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="2dp"
        android:hint="Tape ici..."
        android:textColorHint="#FF3A6080"/>

    <!-- Mode scroll -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:scrollbars="none"
        android:background="@color/mode_bar_bg"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="3dp">
        <LinearLayout
            android:id="@+id/ll_modes"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"/>
    </HorizontalScrollView>

    <!-- Row 1: numbers 1–0 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">
        <Button android:id="@+id/k1" style="@style/KeyStyle" android:text="1"/>
        <Button android:id="@+id/k2" style="@style/KeyStyle" android:text="2"/>
        <Button android:id="@+id/k3" style="@style/KeyStyle" android:text="3"/>
        <Button android:id="@+id/k4" style="@style/KeyStyle" android:text="4"/>
        <Button android:id="@+id/k5" style="@style/KeyStyle" android:text="5"/>
        <Button android:id="@+id/k6" style="@style/KeyStyle" android:text="6"/>
        <Button android:id="@+id/k7" style="@style/KeyStyle" android:text="7"/>
        <Button android:id="@+id/k8" style="@style/KeyStyle" android:text="8"/>
        <Button android:id="@+id/k9" style="@style/KeyStyle" android:text="9"/>
        <Button android:id="@+id/k0" style="@style/KeyStyle" android:text="0"/>
    </LinearLayout>

    <!-- Row 2 AZERTY: a z e r t y u i o p -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:layout_marginTop="3dp">
        <Button android:id="@+id/ka" style="@style/KeyStyle" android:text="a"/>
        <Button android:id="@+id/kz" style="@style/KeyStyle" android:text="z"/>
        <Button android:id="@+id/ke" style="@style/KeyStyle" android:text="e"/>
        <Button android:id="@+id/kr" style="@style/KeyStyle" android:text="r"/>
        <Button android:id="@+id/kt" style="@style/KeyStyle" android:text="t"/>
        <Button android:id="@+id/ky" style="@style/KeyStyle" android:text="y"/>
        <Button android:id="@+id/ku" style="@style/KeyStyle" android:text="u"/>
        <Button android:id="@+id/ki" style="@style/KeyStyle" android:text="i"/>
        <Button android:id="@+id/ko" style="@style/KeyStyle" android:text="o"/>
        <Button android:id="@+id/kp" style="@style/KeyStyle" android:text="p"/>
    </LinearLayout>

    <!-- Row 3 AZERTY: q s d f g h j k l m -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:layout_marginTop="3dp"
        android:gravity="center_horizontal">
        <Button android:id="@+id/kq" style="@style/KeyStyle" android:text="q"/>
        <Button android:id="@+id/ks" style="@style/KeyStyle" android:text="s"/>
        <Button android:id="@+id/kd" style="@style/KeyStyle" android:text="d"/>
        <Button android:id="@+id/kf" style="@style/KeyStyle" android:text="f"/>
        <Button android:id="@+id/kg" style="@style/KeyStyle" android:text="g"/>
        <Button android:id="@+id/kh" style="@style/KeyStyle" android:text="h"/>
        <Button android:id="@+id/kj" style="@style/KeyStyle" android:text="j"/>
        <Button android:id="@+id/kk" style="@style/KeyStyle" android:text="k"/>
        <Button android:id="@+id/kl" style="@style/KeyStyle" android:text="l"/>
        <Button android:id="@+id/km" style="@style/KeyStyle" android:text="m"/>
    </LinearLayout>

    <!-- Row 4: ⇧  w x c v b n .  ⌫ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:layout_marginTop="3dp">
        <Button android:id="@+id/kshift"     style="@style/KeySpecialStyle" android:text="⇧" android:layout_weight="1.5"/>
        <Button android:id="@+id/kw"         style="@style/KeyStyle"        android:text="w"/>
        <Button android:id="@+id/kx"         style="@style/KeyStyle"        android:text="x"/>
        <Button android:id="@+id/kc"         style="@style/KeyStyle"        android:text="c"/>
        <Button android:id="@+id/kv"         style="@style/KeyStyle"        android:text="v"/>
        <Button android:id="@+id/kb"         style="@style/KeyStyle"        android:text="b"/>
        <Button android:id="@+id/kn"         style="@style/KeyStyle"        android:text="n"/>
        <Button android:id="@+id/kdot"       style="@style/KeyStyle"        android:text="."/>
        <Button android:id="@+id/kbackspace" style="@style/KeySpecialStyle" android:text="⌫" android:layout_weight="1.5"/>
    </LinearLayout>

    <!-- Row 5: copy / paste / paste+convert -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:layout_marginTop="3dp">
        <Button android:id="@+id/kcopy"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📋 COPIER"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/key_copy"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>
        <Button android:id="@+id/kpaste"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="📥 COLLER"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/key_paste"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>
        <Button android:id="@+id/kpastesend"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.3"
            android:text="COLLER+CONV"
            android:textSize="8sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/key_pastesend"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

    <!-- Row 6: CLR | -  [espace]  !#  @  ENVOYER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:orientation="horizontal"
        android:layout_marginTop="3dp">

        <Button android:id="@+id/kclear"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="CLR"
            android:textSize="11sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/key_clear"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/kpipe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.7"
            android:text="|"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFF9F0A"
            android:background="@drawable/key_special"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/kdash"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.7"
            android:text="-"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/key_special"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/kspace"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2.1"
            android:text="espace"
            android:textSize="12sp"
            android:fontFamily="sans-serif"
            android:textColor="#FF8E8E93"
            android:background="@drawable/key_space"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/ksymbol"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.9"
            android:text="!#"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FF64D2FF"
            android:background="@drawable/key_sym"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/kat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.7"
            android:text="@"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/key_special"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>

        <Button android:id="@+id/ksend"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.4"
            android:text="ENVOYER"
            android:textSize="9sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="#FFFFFFFF"
            android:background="@drawable/key_send"
            android:layout_margin="3dp"
            android:stateListAnimator="@null"/>
    </LinearLayout>

</LinearLayout>
